# Copy this file to .env and fill in your credentials
# DO NOT commit .env to git

# DAVID Web Service - register at https://davidbioinformatics.nih.gov/webservice/register.htm
# Requires an organizational email (no gmail/yahoo/hotmail)
DAVID_EMAIL=your.email@university.edu

# DisGeNET API - register at https://disgenet.com/academic-apply
# Free academic license requires manual review
DISGENET_API_KEY=your-api-key-here
